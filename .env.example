# Server port (Render sets this automatically; safe to leave as-is)
PORT=3000

# Groq API key used by server.js's /api/ai proxy.
GROQ_API_KEY=your_groq_api_key_here

# Optional private app login. Set both values to enable basic auth.
APP_USER=your_username
APP_PASS=your_password

# Optional AI-only rate limit controls.
AI_RATE_WINDOW_MS=60000
AI_RATE_MAX=20
