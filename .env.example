# Copy this file to .env and fill in your own values.
# Never commit your real .env file.

# Required for the "Ask AI tutor", "Generate insights" and "Syllabus -> tasks"
# features. Get a key at https://console.groq.com/keys
GROQ_API_KEY=

# Port the server listens on.
PORT=3000

# Optional but recommended: protects the whole site with a single shared
# username/password (HTTP Basic Auth) since anyone with the URL can now use
# your AI quota. Leave both blank to disable (not recommended for a
# public URL).
APP_USER=
APP_PASS=

# Max number of AI calls (chat/insights/syllabus combined) allowed per hour,
# across both of you. Keeps a runaway loop or a leaked link from burning
# through your API credits.
AI_RATE_LIMIT_PER_HOUR=60
